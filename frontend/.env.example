# URL of your deployed backend (required for Strava URL integration).
# GPX file upload works without this - no backend needed.
# Example: https://your-backend.railway.app
VITE_BACKEND_URL=

# Base path for the app. Set to /your-repo-name/ if hosted at
# username.github.io/your-repo-name/. Leave blank (or /) for custom domains.
VITE_BASE_PATH=/
